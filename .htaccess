# 进销存管理系统 - Apache配置
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# 默认首页
DirectoryIndex index.php

# 禁止访问敏感文件
<FilesMatch "\.(sql|lock|log|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP设置（如果允许）
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 20M
    php_value max_execution_time 300
</IfModule>
